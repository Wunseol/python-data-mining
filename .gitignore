# ---- Python 编译文件 ----
__pycache__/
*.py[cod]
*$py.class
*.so

# ---- 虚拟环境 ----
venv/
.venv/
env/
.env/

# ---- IDE / 编辑器 ----
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---- Jupyter Notebook ----
.ipynb_checkpoints/
*.ipynb

# ---- 操作系统 ----
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ---- 日志 ----
*.log

# ---- 打包 / 发布 ----
dist/
build/
*.egg-info/
*.egg

# ---- 代码覆盖率 ----
htmlcov/
.coverage
.coverage.*
coverage.xml

# ---- 临时文件 ----
*.tmp
*.bak
*.cache

# ---- CodeBuddy ----
.codebuddy/

