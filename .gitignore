# ==============================
# Python 数据挖掘项目 .gitignore
# ==============================

# ---- Python 编译文件 ----
__pycache__/
*.py[cod]
*$py.class
*.so

# ---- 虚拟环境 ----
venv/
.venv/
env/
.env/

# ---- IDE / 编辑器 ----
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ---- Jupyter Notebook ----
.ipynb_checkpoints/
*.ipynb

# ---- 操作系统 ----
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ---- 大文件（超过 GitHub 限制） ----
# GitHub 单文件限制 100MB，建议超过 25MB 的文件不提交
*.h5
*.hdf5
*.pkl
*.joblib
*.zip

# 具体的大文件
07_无监督学习/02_关联规则挖掘/02_FPGrowth算法/kosarak.dat

# ---- 日志 ----
*.log

# ---- 打包 / 发布 ----
dist/
build/
*.egg-info/
*.egg

# ---- 代码覆盖率 ----
htmlcov/
.coverage
.coverage.*
coverage.xml

# ---- 临时文件 ----
*.tmp
*.bak
*.cache

# ---- CodeBuddy ----
.codebuddy/
